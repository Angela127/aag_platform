# Google Gemini API Key for the AI Memory Assistant
# Get your key from: https://aistudio.google.com/apikey
# This is read by the frontend via Vite's import.meta.env
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Selection (e.g. gemini-2.5-flash, gemini-1.5-flash, gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-flash
